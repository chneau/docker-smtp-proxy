{
	"name": "docker-smtp-proxy",
	"module": "index.ts",
	"type": "module",
	"scripts": {
		"start": "bun index.ts",
		"dev": "bun --watch index.ts",
		"build": "bun build index.ts --target=bun --outdir=dist",
		"upgrade": "bun update --latest",
		"lint": "tsc --noEmit",
		"check": "bun run --sequential --no-exit-on-error check:clean check:deno check:oxlint check:biome check:export lint",
		"publish": "docker build --pull --push --tag ghcr.io/chneau/smtp-proxy .",
		"all": "bun run --sequential --no-exit-on-error upgrade check",
		"check:clean": "rm -rf dist out build",
		"check:deno": "deno fmt --use-tabs --quiet",
		"check:oxlint": "oxlint --fix-dangerously --quiet",
		"check:biome": "timeout 3s biome check --write --unsafe .",
		"check:export": "ts-unused-exports tsconfig.json --excludePathsFromReport=index.ts"
	},
	"dependencies": {
		"@hono/standard-validator": "^0.2.2",
		"@hono/swagger-ui": "^0.6.1",
		"@hono/zod-validator": "^0.8.0",
		"@scalar/hono-api-reference": "^0.10.20",
		"hono": "^4.12.23",
		"hono-openapi": "^1.3.0",
		"nodemailer": "^8.0.10",
		"zod": "^4.4.3",
		"zod-openapi": "^5.4.6"
	},
	"devDependencies": {
		"@types/bun": "^1.3.14",
		"@types/nodemailer": "^8.0.0",
		"typescript": "^6.0.3"
	}
}
